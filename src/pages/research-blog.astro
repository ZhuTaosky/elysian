---
import globalSettings from "@config/config.json.ts";
import BaseLayout from "@layouts/BaseLayout.astro";
import BlogTimeline from "@components/BlogTimeline.astro";

const t = (
  await import(/* @vite-ignore */ `@locales/${globalSettings.language}.json`).catch(
    () => import(/* @vite-ignore */ "@locales/en.json"),
  )
).default;
---

<BaseLayout
  globalSettings={globalSettings}
  t={t}
  title="Research Blog"
  description="Research blog posts archived by year"
>
  <main class="wide-container section-padding-top section-padding-bottom">
    <BlogTimeline title="Research blog" tag="research-blog" />
  </main>
</BaseLayout>
